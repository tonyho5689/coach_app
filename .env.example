# Optional: provide an Anthropic API key to enable real LLM meal-vision analysis
# and a live Advisor chat. Without a key, the app uses realistic mocked results.
#
# Copy this file to ".env" and fill in your key, then restart `expo start`.
# Expo only exposes variables prefixed with EXPO_PUBLIC_ to the app.
EXPO_PUBLIC_ANTHROPIC_API_KEY=
# Optional model override (defaults to claude-sonnet-4-6)
EXPO_PUBLIC_ANTHROPIC_MODEL=claude-sonnet-4-6

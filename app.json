{
  "expo": {
    "name": "Coach",
    "slug": "coach-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "coach",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Coach uses your camera to photograph meals and to track exercise reps.",
        "NSPhotoLibraryUsageDescription": "Coach lets you pick meal photos from your library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F172A"
      },
      "permissions": ["CAMERA"]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Coach uses your camera to photograph meals and track exercise reps."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Coach lets you pick meal photos from your library."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
